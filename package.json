{
	"name": "lahijunat-live",
	"type": "module",
	"version": "1.16.0",
	"packageManager": "pnpm@11.0.8",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && node -e \"fs.copyFileSync('src/sw-utils.js', 'dist/sw-utils.js')\" && workbox generateSW workbox-config.cjs",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check --write src",
		"lint:check": "biome check src",
		"format": "biome format --write src",
		"typecheck": "astro check",
		"check-stations": "pnpm tsx scripts/findStationsWithoutDestinations.ts",
		"update-station-query": "pnpm tsx scripts/updateStationQuery.ts",
		"test-station-query": "pnpm tsx scripts/testStationQuery.ts",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": [
			"biome check --write"
		]
	},
	"dependencies": {
		"@astrojs/preact": "^5.1.4",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.0",
		"astro": "^6.4.2",
		"preact": "^10.29.2",
		"tailwindcss": "^4.3.0",
		"workbox-cacheable-response": "^7.4.1",
		"workbox-core": "^7.4.1",
		"workbox-expiration": "^7.4.1",
		"workbox-precaching": "^7.4.1",
		"workbox-routing": "^7.4.1",
		"workbox-strategies": "^7.4.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@babel/plugin-bugfix-firefox-class-in-computed-class-key": "^7.29.7",
		"@biomejs/biome": "^2.4.16",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/preact": "^3.2.4",
		"@types/node": "^24.12.4",
		"daisyui": "^5.5.20",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8",
		"workbox-cli": "^7.4.1"
	}
}
