{
	"name": "lahijunat-live",
	"type": "module",
	"version": "1.18.0",
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && node scripts/stampSwVersion.mjs && workbox generateSW workbox-config.cjs",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check --write src",
		"lint:check": "biome check src",
		"format": "biome format --write src",
		"typecheck": "astro check",
		"check-stations": "pnpm tsx scripts/findStationsWithoutDestinations.ts",
		"update-station-query": "pnpm tsx scripts/updateStationQuery.ts",
		"update-stations-snapshot": "pnpm tsx scripts/updateStationsSnapshot.ts",
		"test-station-query": "pnpm tsx scripts/testStationQuery.ts",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": [
			"biome check --write"
		]
	},
	"dependencies": {
		"@astrojs/preact": "^6.0.1",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.2",
		"astro": "^7.0.6",
		"preact": "^10.29.7",
		"qrcode-generator": "^2.0.4",
		"tailwindcss": "^4.3.2",
		"workbox-cacheable-response": "^7.4.1",
		"workbox-core": "^7.4.1",
		"workbox-expiration": "^7.4.1",
		"workbox-precaching": "^7.4.1",
		"workbox-routing": "^7.4.1",
		"workbox-strategies": "^7.4.1"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@babel/plugin-bugfix-firefox-class-in-computed-class-key": "^7.29.7",
		"@biomejs/biome": "^2.5.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/preact": "^3.2.4",
		"@types/node": "^24.13.2",
		"daisyui": "^5.6.16",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10",
		"workbox-cli": "^7.4.1"
	}
}
