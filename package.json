{
	"name": "lahijunat-live",
	"type": "module",
	"version": "1.14.0",
	"packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && cp src/sw-utils.js dist/ && workbox generateSW workbox-config.cjs",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check --write src",
		"lint:check": "biome check src",
		"format": "biome format --write src",
		"typecheck": "astro check",
		"check-stations": "pnpm tsx scripts/findStationsWithoutDestinations.ts",
		"update-station-query": "pnpm tsx scripts/updateStationQuery.ts",
		"test-station-query": "pnpm tsx scripts/testStationQuery.ts",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": [
			"biome check --write"
		]
	},
	"dependencies": {
		"@astrojs/preact": "^4.1.3",
		"@astrojs/sitemap": "^3.7.0",
		"@tailwindcss/vite": "^4.2.1",
		"astro": "^5.18.0",
		"preact": "^10.28.4",
		"tailwindcss": "^4.2.1",
		"workbox-cacheable-response": "^7.4.0",
		"workbox-core": "^7.4.0",
		"workbox-expiration": "^7.4.0",
		"workbox-precaching": "^7.4.0",
		"workbox-routing": "^7.4.0",
		"workbox-strategies": "^7.4.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.6",
		"@babel/plugin-bugfix-firefox-class-in-computed-class-key": "^7.28.5",
		"@biomejs/biome": "2.4.6",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/preact": "^3.2.4",
		"@types/node": "~24.0.15",
		"daisyui": "^5.5.19",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.3.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"workbox-cli": "^7.4.0"
	}
}
